Headless, SDL-free OSD provider set for the vendored MU100 build.

Replaces osd_common_t::register_options() with a minimal provider set
(font/render/sound/midi/input/output/debug/netdev = none) plus an inline
headless monitor module (the only provider type lacking a built-in 'none').
This lets the module link with no libSDL3/OpenGL/bgfx/CoreAudio dependency —
a self-contained dsp.so. The tree is then headless-only: run -video none
-sound none. Revert the '#if 0' to restore the stock OSD.

--- a/src/osd/modules/lib/osdobj_common.cpp
+++ b/src/osd/modules/lib/osdobj_common.cpp
@@ -209,8 +209,58 @@
 }
 
 #define REGISTER_MODULE(O, X) { extern const module_type X; O.register_module(X); }
+
+// awm2: headless monitor module — the only provider type with no built-in
+// "none" variant. Defining it here lets register_options() register a fully
+// SDL-free provider set, so a vendored headless build links with no libSDL3 /
+// OpenGL / bgfx / CoreAudio dependency. Nothing is displayed; it just returns a
+// single fake monitor on demand (rarely queried in a windowless run).
+namespace {
+
+class headless_monitor_info : public osd_monitor_info
+{
+public:
+	explicit headless_monitor_info(monitor_module &m)
+		: osd_monitor_info(m, 1, "headless", 1.0f) { m_is_primary = true; update_resolution(640, 480); }
+	virtual void refresh() override { update_resolution(640, 480); }
+};
+
+class headless_monitor_module : public monitor_module
+{
+public:
+	headless_monitor_module() : monitor_module(OSD_MONITOR_PROVIDER, "headless") {}
+	virtual int  init(osd_interface &, const osd_options &) override { return 0; }
+	virtual std::shared_ptr<osd_monitor_info> monitor_from_handle(std::uint64_t) override { return mon(); }
+	virtual std::shared_ptr<osd_monitor_info> monitor_from_rect(const osd_rect &) override { return mon(); }
+	virtual std::shared_ptr<osd_monitor_info> monitor_from_window(const osd_window &) override { return mon(); }
+	virtual std::shared_ptr<osd_monitor_info> pick_monitor(osd_options &, int) override { return mon(); }
+private:
+	std::shared_ptr<osd_monitor_info> m_mon;
+	std::shared_ptr<osd_monitor_info> mon() { if (!m_mon) m_mon = std::make_shared<headless_monitor_info>(*this); return m_mon; }
+};
+
+} // anonymous namespace
+
+MODULE_DEFINITION(MONITOR_HEADLESS, headless_monitor_module)
+
 void osd_common_t::register_options()
 {
+	// awm2: minimal SDL-free provider set (the full SDL/OpenGL/bgfx/CoreAudio
+	// set below is disabled). This vendored MAME tree is headless-only: run with
+	// -video none -sound none. Revert the #if 0 to restore the stock OSD.
+	REGISTER_MODULE(m_mod_man, FONT_NONE);
+	REGISTER_MODULE(m_mod_man, RENDERER_NONE);
+	REGISTER_MODULE(m_mod_man, SOUND_NONE);
+	REGISTER_MODULE(m_mod_man, MONITOR_HEADLESS);
+	REGISTER_MODULE(m_mod_man, KEYBOARD_NONE);
+	REGISTER_MODULE(m_mod_man, MOUSE_NONE);
+	REGISTER_MODULE(m_mod_man, LIGHTGUN_NONE);
+	REGISTER_MODULE(m_mod_man, JOYSTICK_NONE);
+	REGISTER_MODULE(m_mod_man, MIDI_NONE);
+	REGISTER_MODULE(m_mod_man, OUTPUT_NONE);
+	REGISTER_MODULE(m_mod_man, DEBUG_NONE);
+	REGISTER_MODULE(m_mod_man, NETDEV_NONE);
+#if 0  // awm2: stock SDL/OpenGL/bgfx/CoreAudio provider set disabled for headless link
 	REGISTER_MODULE(m_mod_man, FONT_OSX);
 	REGISTER_MODULE(m_mod_man, FONT_WINDOWS);
 	REGISTER_MODULE(m_mod_man, FONT_DWRITE);
@@ -330,6 +380,7 @@
 	REGISTER_MODULE(m_mod_man, OUTPUT_CONSOLE);
 	REGISTER_MODULE(m_mod_man, OUTPUT_NETWORK);
 	REGISTER_MODULE(m_mod_man, OUTPUT_WIN32);
+#endif  // awm2: end disabled stock provider set
 
 
 	// after initialization we know which modules are supported
